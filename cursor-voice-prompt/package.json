{
  "name": "cursor-voice-prompt",
  "version": "0.1.0",
  "description": "Cursor 语音 Prompt 输入小工具（自用）",
  "main": "electron/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.local.cursor-voice-prompt",
    "productName": "CursorVoicePrompt",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": ["portable"],
      "artifactName": "${productName}-${version}-portable.exe"
    }
  }
}
